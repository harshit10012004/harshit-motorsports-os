---
import { ClientOnly } from 'astro/components';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Motorsports OS - Week 1 Complete</title>
</head>

<body class="bg-slate-900 text-white p-8 font-sans">
  <header class="mb-12 p-6 bg-black/50 rounded-lg">
    <div class="max-w-4xl mx-auto flex flex-col lg:flex-row gap-4 lg:gap-8 items-center lg:items-center">
      <h1 class="text-4xl font-bold bg-gradient-to-r from-teal-400 to-blue-500 text-transparent bg-clip-text">
        Motorsports OS
      </h1>
      <nav class="flex gap-6 text-slate-400">
        <a href="/" class="hover:text-teal-400 font-medium">Home</a>
        <a href="/projects" class="hover:text-teal-400 font-medium">Projects</a>
        <a href="/about" class="hover:text-teal-400 font-medium">About</a>
      </nav>
    </div>
  </header>

  <main class="max-w-4xl mx-auto">
    <section class="mb-20">
      <h1 class="text-6xl font-black mb-8 bg-gradient-to-r from-teal-400 to-blue-400 text-transparent bg-clip-text">
        Harshit Sharma
      </h1>
      <h2 class="text-3xl font-bold text-slate-200 mb-6">F1 Data Engineer</h2>
      <p class="text-xl text-slate-400 mb-8 max-w-2xl">
        Week 1 complete: Live F1 dashboard with Recharts telemetry.
      </p>
      <div class="bg-black/50 p-8 rounded-xl border border-gray-700 mb-20">
        <h3 class="text-2xl font-bold mb-4 text-teal-400">Telemetry Loading...</h3>
        <p class="text-slate-400">ClientOnly + Recharts component ready</p>
      </div>
    </section>

    <section>
      <h2 class="text-4xl font-black mb-12 text-center text-white">Projects Grid</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-black/50 p-8 rounded-xl border border-gray-700 hover:border-teal-500 hover:bg-teal-500/5 transition-all">
          <h3 class="font-bold text-xl mb-3">RB19 Optimizer</h3>
          <p class="text-teal-400 mb-4">ML Lap Time Prediction</p>
          <span class="text-sm text-slate-500">0.3s faster laps</span>
        </div>
        <div class="bg-black/50 p-8 rounded-xl border border-gray-700 hover:border-teal-500 hover:bg-teal-500/5 transition-all">
          <h3 class="font-bold text-xl mb-3">Wheel of Life</h3>
          <p class="text-teal-400 mb-4">Expertise Radar Chart</p>
        </div>
        <div class="bg-black/50 p-8 rounded-xl border border-gray-700 hover:border-teal-500 hover:bg-teal-500/5 transition-all">
          <h3 class="font-bold text-xl mb-3">Live Telemetry</h3>
          <p class="text-teal-400 mb-4">Real-time Data</p>
        </div>
        <div class="bg-black/50 p-8 rounded-xl border border-gray-700 hover:border-teal-500 hover:bg-teal-500/5 transition-all">
          <h3 class="font-bold text-xl mb-3">F2004 Aero</h3>
          <p class="text-teal-400 mb-4">3D Analysis</p>
        </div>
        <div class="bg-black/50 p-8 rounded-xl border border-gray-700 hover:border-teal-500 hover:bg-teal-500/5 transition-all">
          <h3 class="font-bold text-xl mb-3">Pit Stop Opti</h3>
          <p class="text-teal-400 mb-4">Genetic Algorithm</p>
        </div>
        <div class="bg-black/50 p-8 rounded-xl border border-gray-700 hover:border-teal-500 hover:bg-teal-500/5 transition-all">
          <h3 class="font-bold text-xl mb-3">Downforce ML</h3>
          <p class="text-teal-400 mb-4">Neural Network</p>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
