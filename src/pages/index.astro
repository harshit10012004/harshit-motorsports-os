<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Harshit Sharma · motorsport engineer</title>
  
  <!-- Font Awesome + Google Fonts (CDN) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="dashboard">
    <!-- LEFT RAIL (Your exact design) -->
    <aside class="left-rail">
      <a href="index.html">
        <!-- Replace with your actual logo -->
        <img src="Harshit-Sharma.png" alt="Harshit Sharma logo" class="nav-logo">
      </a>
      <div class="nav-icons">
        <a href="index.html"><i class="fas fa-home"></i></a>
        <a href="#"><i class="fas fa-project-diagram"></i></a>
        <a href="about.html"><i class="fas fa-user"></i></a>
        <a href="#contact"><i class="fas fa-envelope"></i></a>
      </div>
      <div class="social-icons">
        <a href="#"><i class="fab fa-linkedin-in"></i></a>
        <a href="#"><i class="fab fa-github"></i></a>
        <a href="#"><i class="fab fa-x-twitter"></i></a>
      </div>
    </aside>

    <!-- MAIN CONTENT AREA (Add your hero/projects here) -->
    <main class="main-content">
      <section class="hero">
        <h1>Harshit Sharma</h1>
        <h2>Motorsport Data Engineer</h2>
        <p>Building ML models that win races. RB19 optimization.</p>
      </section>
      
      <!-- Your existing Bento grid goes here -->
      <section class="projects-grid">
        <div class="project-card">
          <h3>RB19 Lap Optimizer</h3>
          <p>0.3s lap time gains</p>
        </div>
        <!-- Add more cards -->
      </section>
    </main>
  </div>
</body>
</html>

